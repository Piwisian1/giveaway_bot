# Telegram bot token from @BotFather
BOT_TOKEN=123456789:your-bot-token-here

# Comma-separated Telegram user IDs allowed into the admin panel
ADMIN_IDS=123456789

# Path to the SQLite database file
DB_PATH=data/bot.db

# Directory for log files
LOG_DIR=logs

# Seconds between live refreshes of giveaway announcement messages
# (participant count + remaining time) — see bot/background/live_updater.py
LIVE_UPDATE_INTERVAL=20

# Seconds between checks for giveaways that have passed their end time
# — see bot/background/auto_closer.py
AUTO_CLOSE_INTERVAL=30
